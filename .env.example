# =============================================================================
# Agicom Frontend – Environment Config Example
# =============================================================================
# The frontend is plain HTML/CSS/JS – there is no build step that reads .env
# files automatically.  Instead, edit assets/js/config.js directly:
#
#   window.__AGICOM_CONFIG__ = {
#       API_BASE_URL: 'http://localhost:8000',  ← change this for staging/prod
#   };
#
# This file is kept for documentation purposes and CI pipelines that may
# substitute values with sed/envsubst before deployment.

# FastAPI backend base URL (no trailing slash)
API_BASE_URL=http://localhost:8000
